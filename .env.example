# Scraper Benchmark — API Keys
# Copy this file to .env and fill in the keys for the scrapers you want to test.
# Any scraper whose key is missing will be skipped automatically.

# Anakin (https://anakin.io — get your key from the dashboard)
ANAKIN_API_KEY=

# Firecrawl (https://firecrawl.dev)
FIRECRAWL_API_KEY=

# ZenRows (https://zenrows.com)
ZENROWS_API_KEY=

# ScraperAPI (https://scraperapi.com)
SCRAPERAPI_KEY=

# Oxylabs (https://oxylabs.io — uses username/password, not a token)
OXYLABS_USERNAME=
OXYLABS_PASSWORD=

# ScrapingBee (https://scrapingbee.com — acquired by Oxylabs, Jun 2025)
SCRAPINGBEE_API_KEY=

# Tavily (https://tavily.com — uses /extract endpoint for single-URL content)
TAVILY_API_KEY=
